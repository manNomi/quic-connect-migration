# Copy this file to harness/config/aws.env and edit locally.
# Do not commit real credentials.

# AWS CLI profile to use. Leave empty to use default AWS CLI behavior.
AWS_PROFILE=

# Primary experiment region.
AWS_REGION=ap-northeast-2

# Resource naming prefix for future EC2/NLB work.
RESOURCE_PREFIX=quic-cm-lab

# Optional SSH key path for EC2 runbook steps.
SSH_KEY_PATH=

# Optional client public CIDR for security group rules.
# Example: 203.0.113.10/32
CLIENT_PUBLIC_CIDR=
