# Copy this file to harness/config/experiment.env and edit locally.

# quic-go local/direct-origin parameters
PORT=4242
PAYLOAD_BYTES=1048576
PROBE_TIMEOUT=3s
TIMEOUT=30s

# EC2 client defaults
EC2_PROBE_TIMEOUT=5s
EC2_TIMEOUT=60s

# Optional override. Usually leave empty so harness creates a timestamped run id.
RUN_ID=
